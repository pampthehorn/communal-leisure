{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "2678bdbd-753b-4990-85be-382f8a473ea9",
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": false
        }
      },
      "DeliveryApi": {
        "Enabled": true
      },
      "Unattended": {
        "UpgradeUnattended": false
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "ModelsBuilder": {
        "ModelsMode": "SourceCodeManual"
      }
    }

  },

  "Turnstile": {
    "SiteKey": "1x00000000000000000000AA",
    "SecretKey": "1x0000000000000000000000000000000AA"
    // Cloudflare-published dummy keys for local dev. Always-pass visible widget.
    // Swap in to exercise other paths:
    //   Always-block:      site "2x00000000000000000000AB" / secret "2x0000000000000000000000000000000AA"
    //   Force interactive: site "3x00000000000000000000FF" / secret "3x0000000000000000000000000000000AA"
  }
}
