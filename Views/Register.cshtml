@using website.Controllers
@using website.Models.ViewModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = "_Layout.cshtml";

    var verifyResult = ViewBag.VerifyResult as string;
    var verifyMessage = ViewBag.VerifyMessage as string;
    var isVerifying = Context.Request.Query["verify"].ToString() == "true";
    var isRegistered = TempData["RegisterStatus"]?.ToString() == "registered";
}

@if (isVerifying && !string.IsNullOrEmpty(verifyResult))
{
    <h2>Email Verification</h2>

    if (verifyResult == "success")
    {
        <div class="alert alert-success">@verifyMessage</div>
    }
    else
    {
        <div class="alert alert-danger">@verifyMessage</div>
    }
}
else if (isRegistered)
{
    <h2>Check Your Email</h2>
    <div class="alert alert-success">
        Registration successful! We've sent a verification link to your email address. Please click the link to verify your email.
    </div>
}
else
{
    <h2>Register</h2>
    <p>Create an account to submit and manage your own events.</p>

    <small id="pw-help" class="form-text text-muted">
        Your password must:
        <ul>
            <li>Be at least @ViewBag.RequiredLength characters long.</li>
            @if ((bool)(ViewBag.RequireDigit ?? false))
            {
                <li>Contain at least one number (0-9).</li>
            }
            @if ((bool)(ViewBag.RequireLowercase ?? false))
            {
                <li>Contain at least one lowercase letter (a-z).</li>
            }
            @if ((bool)(ViewBag.RequireUppercase ?? false))
            {
                <li>Contain at least one uppercase letter (A-Z).</li>
            }
            @if ((bool)(ViewBag.RequireNonLetterOrDigit ?? false))
            {
                <li>Contain at least one special character (e.g., !@@#$).</li>
            }
        </ul>
    </small>

    @using (Html.BeginUmbracoForm<RegistrationSurfaceController>("HandleRegister", FormMethod.Post))
    {
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.Label("Name", "Name")
            @Html.TextBox("Name", "", new { @class = "form-control", required = "required" })
            @Html.ValidationMessage("Name", "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.Label("Email", "Email")
            @Html.TextBox("Email", null, new { @class = "form-control", type = "email", required = "required" })
            @Html.ValidationMessage("Email", "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.Label("Password", "Password")
            @Html.Password("Password", null, new { @class = "form-control", aria_describedby = "pw-help", required = "required" })
            @Html.ValidationMessage("Password", "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.Label("ConfirmPassword", "Confirm Password")
            @Html.Password("ConfirmPassword", null, new { @class = "form-control", required = "required" })
            @Html.ValidationMessage("ConfirmPassword", "", new { @class = "text-danger" })
        </div>
        <br />
        <button type="submit" class="btn btn-primary">Register</button>
    }
}
