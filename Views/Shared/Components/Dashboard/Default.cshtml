@using Umbraco.Cms.Web.Website.Controllers
@using Umbraco.Cms.Web.Common.Models
@using website.Controllers
@using website.Models

@model DashboardViewModel

@{
    var dateFormat = "ddd d MMM HH:mm";
    var logoutModel = new PostRedirectModel { RedirectUrl = null };
    var promoterRequestStatus = TempData["PromoterRequestStatus"] as string;
}

<h2>Dashboard</h2>

<p>Logged in as <strong>@Model.MemberName</strong></p>

<div style="margin-bottom: 20px;">
    <a href="/add-event">Add Event</a>
    &nbsp;|&nbsp;
    @using (Html.BeginUmbracoForm<UmbLoginStatusController>("HandleLogout", new { RedirectUrl = logoutModel.RedirectUrl }))
    {
        <button type="submit" style="background: none; border: none; padding: 0; cursor: pointer; text-decoration: underline; font-size: inherit; font-family: inherit;">Log out</button>
    }
</div>

<div class="promoter-status" style="margin-bottom: 24px; padding: 12px; border: 1px solid #ddd;">
    @if (promoterRequestStatus == "requested")
    {
        <div class="alert alert-success">Thanks — we've passed your promoter request to the admins. You'll hear back soon.</div>
    }
    else if (promoterRequestStatus == "alreadyApproved")
    {
        <div class="alert alert-info">You're already approved as a promoter.</div>
    }

    @switch (Model.PromoterStatus)
    {
        case PromoterStatus.Approved:
            <p><strong>Promoter:</strong> approved — your events go live without admin approval.</p>
            break;

        case PromoterStatus.Pending:
            <p><strong>Promoter:</strong> pending admin approval.</p>
            break;

        case PromoterStatus.None:
            <p>Want to add your own gigs? Promoter status lets you publish events without waiting for admin approval.</p>
            @using (Html.BeginUmbracoForm<RegistrationSurfaceController>("RequestPromoter", FormMethod.Post))
            {
                <button type="submit" class="btn btn-primary">I would like to add my own gigs</button>
            }
            break;
    }
</div>

@if (Model.MyTickets.Any())
{
    <h3>My Tickets</h3>
    <ul class="listing list-view my-tickets">
        @foreach (var group in Model.MyTickets)
        {
            string whenLine = "";
            if (group.EventStartDate.HasValue)
            {
                var startUk = UkDateHelper.ToUkTime(group.EventStartDate.Value);
                whenLine = startUk.ToString(dateFormat);
            }

            <li class="event-text-item @(group.IsPastEvent ? "past-ticket" : "")">
                <div class="event-details">
                    <h3>
                        @if (!string.IsNullOrEmpty(group.EventUrl))
                        {
                            <a href="@group.EventUrl">@group.EventName</a>
                        }
                        else
                        {
                            @group.EventName
                        }
                    </h3>
                    @if (!string.IsNullOrEmpty(whenLine))
                    {
                        <p class="event-date"><time>@whenLine</time></p>
                    }
                    @if (!string.IsNullOrEmpty(group.Venue))
                    {
                        <p>@group.Venue</p>
                    }

                    @foreach (var line in group.Lines)
                    {
                        <div class="ticket-line" style="margin: 8px 0;">
                            <strong>@line.Quantity x @line.Type</strong>
                            @if (line.Codes.Any())
                            {
                                <ul style="margin: 4px 0 0 0; padding-left: 18px;">
                                    @foreach (var code in line.Codes)
                                    {
                                        <li><code>@code</code></li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span style="color: #888;"> (codes pending)</span>
                            }
                        </div>
                    }

                    <p style="font-size: 0.85em; color: #666;">
                        Order #@group.OrderId &middot; purchased @group.OrderDate.ToUniversalTime().ToString("d MMM yyyy")
                    </p>
                </div>
            </li>
        }
    </ul>
}

@if (Model.UpcomingEvents.Any())
{
    <h3>Upcoming Events</h3>
    <ul class="listing list-view">
        @foreach (var item in Model.UpcomingEvents)
        {
            var e = item.Event;
            var startDate = UkDateHelper.ToUkTime(e.startDate);
            var endDate = UkDateHelper.ToUkTime(e.endDate);
            string displayDate = $"{startDate.ToString(dateFormat)} - {(startDate.Date != endDate.Date ? endDate.ToString(dateFormat) : endDate.ToString("HH:mm"))}";

            <li class="event-text-item">
                <div class="poster-container">
                    <a href="@e.url">
                        <img src="@($"{e.poster.Url}?width=140&height=190&mode=crop&quality=80")" alt="@e.name" class="poster-thumb" />
                    </a>
                    <div class="poster-popover">
                        <img src="@($"{e.poster.Url}?width=400&quality=80")" alt="@e.name" />
                    </div>
                </div>

                <div class="event-details">
                    <p class="event-date">
                        <span title="add to calendar">📅</span>
                        <time>@displayDate</time>
                    </p>
                    <h3><a href="@e.url">@e.name</a></h3>
                    <p>@e.description</p>
                    <p>
                        @if (!string.IsNullOrEmpty(e.venueUrl))
                        {
                            <a href="@e.venueUrl">@e.venue</a>
                        }
                        else
                        {
                            @e.venue
                        }
                        @if (!string.IsNullOrEmpty(e.venueAddress))
                        {
                            <span>@e.venueAddress</span>
                        }
                    </p>

                    @if (item.TicketAllocations.Any())
                    {
                        <div class="ticket-summary">
                            @foreach (var ta in item.TicketAllocations)
                            {
                                <span>
                                    <strong>@ta.Type:</strong>
                                    @ta.Sold@(ta.Allocation > 0 ? $"/{ta.Allocation}" : "")
                                    sold
                                    @if (ta.Allocation > 0 && ta.Sold >= ta.Allocation)
                                    {
                                        <span style="color: red; font-weight: bold;">(SOLD OUT)</span>
                                    }
                                    &nbsp;
                                </span>
                            }
                        </div>
                    }
                </div>
            </li>
        }
    </ul>
}
else
{
    <h3>Upcoming Events</h3>
    <p>No upcoming events.</p>
}

@if (Model.PastEvents.Any())
{
    <h3>Past Events</h3>
    <ul class="listing list-view">
        @foreach (var item in Model.PastEvents)
        {
            var e = item.Event;
            var startDate = UkDateHelper.ToUkTime(e.startDate);
            var endDate = UkDateHelper.ToUkTime(e.endDate);
            string displayDate = $"{startDate.ToString(dateFormat)} - {(startDate.Date != endDate.Date ? endDate.ToString(dateFormat) : endDate.ToString("HH:mm"))}";

            <li class="event-text-item">
                <div class="poster-container">
                    <a href="@e.url">
                        <img src="@($"{e.poster.Url}?width=140&height=190&mode=crop&quality=80")" alt="@e.name" class="poster-thumb" />
                    </a>
                    <div class="poster-popover">
                        <img src="@($"{e.poster.Url}?width=400&quality=80")" alt="@e.name" />
                    </div>
                </div>

                <div class="event-details">
                    <p class="event-date">
                        <time>@displayDate</time>
                    </p>
                    <h3><a href="@e.url">@e.name</a></h3>
                    <p>@e.description</p>
                    <p>
                        @if (!string.IsNullOrEmpty(e.venueUrl))
                        {
                            <a href="@e.venueUrl">@e.venue</a>
                        }
                        else
                        {
                            @e.venue
                        }
                    </p>

                    @if (item.TicketAllocations.Any())
                    {
                        <div class="ticket-summary">
                            @foreach (var ta in item.TicketAllocations)
                            {
                                <span>
                                    <strong>@ta.Type:</strong>
                                    @ta.Sold@(ta.Allocation > 0 ? $"/{ta.Allocation}" : "")
                                    sold
                                    &nbsp;
                                </span>
                            }
                        </div>
                    }
                </div>
            </li>
        }
    </ul>
}
