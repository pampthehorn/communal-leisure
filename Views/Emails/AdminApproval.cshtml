@using website.Controllers
@model AdminApprovalEmailModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
        }
        a {
            color: #000;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <h2>New Member Registration</h2>
    <p>A new member has registered and verified their email address:</p>
    <ul>
        <li><strong>Name:</strong> @Model.MemberName</li>
        <li><strong>Email:</strong> @Model.MemberEmail</li>
    </ul>
    <p>Click the link below to approve this member:</p>
    <p><a href="@Model.ApproveLink">Approve @Model.MemberName</a></p>
    <p>Once approved, the member will be notified by email and able to log in.</p>
    <p><a href="https://communalleisure.com">communalleisure.com</a></p>
</body>
</html>
