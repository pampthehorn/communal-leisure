@using Umbraco.Cms.Core.Security
@using Umbraco.Cms.Core.Services
@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Venues>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using website

@inject IPublishedValueFallback _publishedValueFallback;

@{
    Layout = "_Layout.cshtml";

    var venues = Model.Children().Select(m => new Venue(m, _publishedValueFallback)).GroupBy(m => m.City);
}

@section Head {
    <title>Venues — Glasgow & Edinburgh Gig Venues | Communal Leisure</title>
    <link rel="canonical" href="@Model.Url(mode: UrlMode.Absolute)" />
    <meta name="description" content="Browse gig venues in Glasgow and Edinburgh. Find independent music venues hosting DIY events, live music, and community gatherings.">
    <meta property="og:title" content="Venues — Glasgow & Edinburgh Gig Venues | Communal Leisure">
    <meta property="og:description" content="Browse gig venues in Glasgow and Edinburgh. Find independent music venues hosting DIY events, live music, and community gatherings.">
    <meta property="og:image" content="https://communalleisure.com/img/rabbit.png">
    <meta property="og:url" content="@Model.Url(mode: UrlMode.Absolute)">
    <meta property="og:type" content="website">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Venues — Glasgow & Edinburgh Gig Venues | Communal Leisure">
    <meta name="twitter:description" content="Browse gig venues in Glasgow and Edinburgh. Find independent music venues hosting DIY events, live music, and community gatherings.">
    <meta name="twitter:image" content="https://communalleisure.com/img/rabbit.png">
}

<h1>@Model.Name</h1>

<div class="event-page">
    @foreach (var city in venues)
    {
        
    <h3>@city.Key</h3>    <ul>        @foreach(var venue in city.OrderBy(m=>m.Name.Replace("The ","")))
        {
            <li>
           <a href="@venue.Url()">@venue.Name</a> @venue.Postcode
            </li>
        }
        </ul>
    }

</div>