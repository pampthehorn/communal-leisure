@using Umbraco.Cms.Core.Services
@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Zines>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels

@{
    Layout = "_Layout.cshtml";

    var zines = Model.Children<ContentModels.Zine>()
        .OrderByDescending(z => z.SortOrder)
        .ToList();
}

@section Head {
    <title>Zine archive — Communal Leisure</title>
    <link rel="canonical" href="@Model.Url(mode: UrlMode.Absolute)" />
    <meta name="description" content="Download or read back issues of the Communal Leisure zine.">
    <meta property="og:title" content="Zine archive — Communal Leisure">
    <meta property="og:description" content="Download or read back issues of the Communal Leisure zine.">
    <meta property="og:image" content="https://communalleisure.com/img/rabbit.png">
    <meta property="og:url" content="@Model.Url(mode: UrlMode.Absolute)">
    <meta property="og:type" content="website">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Zine archive — Communal Leisure">
    <meta name="twitter:description" content="Download or read back issues of the Communal Leisure zine.">
    <meta name="twitter:image" content="https://communalleisure.com/img/rabbit.png">
}

<h2>@Model.Name</h2>

<div class="listing" id="zines">
    @foreach (var zine in zines)
    {
        var coverUrl = zine.Cover?.Url();
        var pdfUrl = zine.Pdf?.Url();

        <div>
            <h5>@zine.Name</h5>
            @if (!string.IsNullOrEmpty(coverUrl))
            {
                <a href="@zine.Url()"><img src="@coverUrl" alt="@zine.Name cover" /></a>
            }
            @if (!string.IsNullOrEmpty(pdfUrl))
            {
                <p>
                    <a href="@pdfUrl" download="">Download</a> |
                    <a target="_blank" href="@pdfUrl">Read</a>
                </p>
            }
        </div>
    }
</div>
